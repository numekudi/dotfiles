eval "$(starship init zsh)"
alias copilot="copilot --disable-builtin-mcps"
alias claude="claude --dangerously-skip-permissions"
alias l="ls"
alias ll="ls -l"
alias la="ls -a"
alias lla="ls -la"


if [ -d /Volumes/SSD250/TMPDIR ]; then
    export TMPDIR=/Volumes/SSD250/TMPDIR
fi



