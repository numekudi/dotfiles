eval "$(starship init bash)"
alias copilot="copilot --disable-builtin-mcps"
alias claude="claude --dangerously-skip-permissions"
alias codex="codex --dangerously-bypass-approvals-and-sandbox"
alias l="ls"
alias ll="ls -l"
alias la="ls -a"
alias lla="ls -la"


