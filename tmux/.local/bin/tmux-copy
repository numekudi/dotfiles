#!/usr/bin/env bash

set -euo pipefail

if [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy >/dev/null 2>&1; then
  exec wl-copy
fi

if [[ "${OSTYPE:-}" == darwin* ]] && command -v pbcopy >/dev/null 2>&1; then
  exec pbcopy
fi

if [[ -n "${DISPLAY:-}" ]] && command -v xclip >/dev/null 2>&1; then
  exec xclip -selection clipboard -in
fi

if [[ -n "${DISPLAY:-}" ]] && command -v xsel >/dev/null 2>&1; then
  exec xsel --clipboard --input
fi

if command -v clip.exe >/dev/null 2>&1; then
  exec clip.exe
fi

cat >/dev/null
printf '%s\n' "tmux-copy: no supported clipboard provider found." >&2
printf '%s\n' "Install one of: wl-copy, xclip, xsel, pbcopy, clip.exe." >&2
exit 1
